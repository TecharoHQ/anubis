    "**/.gitkeep",
    "**/*.graffle",
    "**/*.gz",
    "**/*.icns",
    "**/*.ico",
    "**/*.ipynb",
    "**/*.jar",
    "**/*.jks",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.key",
    "**/*.lib",
    "**/*.lock",
    "**/*.map",
    "**/*.min.*",
    "**/*.mo",
    "**/*.mod",
    "**/*.mp3",
    "**/*.mp4",
    "**/*.o",
    "**/*.ocf",
    "**/*.otf",
    "**/*.p12",
    "**/*.parquet",
    "**/*.pdf",
    "**/*.pem",
    "**/*.pfx",
    "**/*.png",
    "**/*.psd",
    "**/*.pyc",
    "**/.pylintrc",
    "**/*.qm",
    "**/*.s",
    "**/*.sig",
    "**/*.so",
    "**/*.svg",
    "**/*.svgz",
    "**/*.sys",
    "**/*.tar",
    "**/*.tgz",
    "**/*.tif",
    "**/*.tiff",
    "**/*.ttf",
    "**/*.wav",
    "**/*.webm",
    "**/*.webp",
    "**/*.woff",
    "**/*.woff2",
    "**/*.xcf",
    "**/*.xls",
    "**/*.xlsx",
    "**/*.xpm",
    "**/*.xz",
    "**/*.zip",
    "**/*ignore",
    "**/robots.txt",
    ".github/FUNDING.yml",
    ".github/workflows/spelling.yml",
    "data/**",
    "docs/blog/tags.yml",
    "docs/docs/user/known-instances.md",
    "docs/manifest/**",
    "docs/static/.nojekyll",
    "internal/glob/glob_test.go",
    "internal/honeypot/naive/affirmations.txt",
    "internal/honeypot/naive/spintext.txt",
