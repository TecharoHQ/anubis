{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "companies",
    "css",
    "en_GB",
    "en_US",
    "filetypes",
    "fonts",
    "golang",
    "html",
    "node",
    "npm",
    "project-words",
    "rust",
    "rust-crates",
    "typescript"
  ],
