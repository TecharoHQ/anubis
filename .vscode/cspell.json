    "**/{LICENSE,LICENCE,license,licence,License,Licence}",
    "**/third-party/**",
    "**/third_party/**",
    "**/thirdparty/**",
    "**/3rdparty/**",
    "**/generated/**",
    "**/vendor/**",
    "**/go.sum",
    "**/package.json",
    "**/package-lock.json",
    "**/Pipfile",
    "**/pyproject.toml",
    "**/requirements*.txt",
