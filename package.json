{
  "name": "@techaro/anubis",
  "version": "1.26.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run assets && SKIP_INTEGRATION=1 go test ./...",
    "test:spelling": "git diff --name-only HEAD | npx cspell --file-list stdin",
    "test:spelling:sort": "node .vscode/scripts/sort-project-words.mjs",
    "test:integration": "npm run assets && go test -v ./internal/test",
    "test:integration:podman": "npm run assets && go test -v ./internal/test --playwright-runner=podman",
    "test:integration:docker": "npm run assets && go test -v ./internal/test --playwright-runner=docker",
    "assets:generate": "go generate ./...",
    "assets:wasm": "bash ./scripts/build_wasm.sh",
    "assets:wasm2js": "bash ./scripts/build_wasm2js.sh",
    "assets:web": "./web/build.sh",
    "assets:xess": "./xess/build.sh",
    "assets": "npm run assets:generate && npm run assets:wasm && npm run assets:wasm2js && npm run assets:web && npm run assets:xess && echo Done",
    "build": "npm run assets && go build -ldflags='-w -s' -o ./var/anubis ./cmd/anubis",
    "dev": "npm run assets && go run ./cmd/anubis --use-remote-address --target http://localhost:3000",
    "container": "npm run assets && go run ./cmd/containerbuild",
    "package": "go tool yeet",
    "lint": "make lint",
    "spellcheck": "cspell --no-progress --config .vscode/cspell.json \"**\"",
    "prepare": "husky && go mod download",
    "format": "prettier -w . 2>&1 >/dev/null && go run goimports -w .",
    "ci": "npm run ci:go && npm run ci:rust && npm run ci:ssh-ci && npm run ci:yeet",
    "ci:go": "act -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 -j go_tests",
    "ci:rust": "npm run ci:rust:fmt && npm run ci:rust:test",
    "ci:rust:fmt": "act -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 -j rust-formatting",
    "ci:rust:test": "act -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 -j rust-test",
    "ci:ssh-ci": "act -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 -j ssh-ci-image-test",
    "ci:yeet": "act -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 -j package_builds"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.0.2",
    "baseline-browser-mapping": "^2.10.40",
    "cspell": "^10.0.1",
    "cssnano": "^8.0.2",
    "cssnano-preset-advanced": "^8.0.2",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "playwright": "^1.61.1",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-import-url": "^7.2.0",
    "postcss-url": "^10.1.4",
    "prettier": "^3.9.1"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "preact": "^10.29.3",
    "wasm-feature-detect": "^1.8.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        2,
        "always",
        99999
      ],
      "footer-max-line-length": [
        2,
        "always",
        99999
      ],
      "signed-off-by": [
        2,
        "always"
      ]
    }
  },
  "prettier": {
    "singleQuote": false,
    "tabWidth": 2,
    "semi": true,
    "trailingComma": "all",
    "printWidth": 80
  }
}